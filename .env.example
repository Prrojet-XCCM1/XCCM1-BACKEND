# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================
# Port used by the application (Default: 8080)
PORT=8082
SPRING_PROFILES_ACTIVE=dev

# ==============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ==============================================================================
# Used by Docker Compose
POSTGRES_VERSION=16
POSTGRES_CONTAINER_NAME=xccm-db
POSTGRES_DB=xccm1
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# Used by the Application (mapped from above in docker-compose.yml)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=xccm1
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password

# ==============================================================================
# SECURITY CONFIGURATION (JWT)
# ==============================================================================
# Random 256-bit key (at least 64 characters)
JWT_SECRET=ce4f01beeee4257f8ae44276369cd65974b8e114a9103cdc738f01c391a9b023
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ==============================================================================
# MAIL CONFIGURATION (SMTP)
# ==============================================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# ==============================================================================
# KAFKA CONFIGURATION
# ==============================================================================
# Internal Docker Kafka settings
KAFKA_CONTAINER_NAME=kafka
KAFKA_PORT=9092
KAFKA_HOST=localhost
# Used by the application
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ==============================================================================
# OAuth2
# ==============================================================================

GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET
GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET
FRONTEND_URL=

# ==============================================================================
# ELASTICSEARCH CONFIGURATION
# ==============================================================================
ELASTICSEARCH_CONTAINER_NAME=elasticsearch
ELASTIC_PORT=9200
ELASTICSEARCH_URIS=http://localhost:9200

# ==============================================================================
# FILE & CORS CONFIGURATION
# ==============================================================================
UPLOAD_DIR=./uploads
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:5173
IP_ADDRESS=http://xxxxxxxx:xxx
